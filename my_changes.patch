diff --git a/apps/frontend/script.py b/apps/frontend/script.py
new file mode 100644
index 00000000..2f2de988
--- /dev/null
+++ b/apps/frontend/script.py
@@ -0,0 +1,51 @@
+﻿import os, re
+
+directory = 'c:/Users/Jean Marc bassahak/Documents/trae_projects/pyramidmail/apps/frontend/src'
+count = 0
+
+def repl_inner(m):
+    return m.group(0).replace('rounded-xl', 'rounded')
+
+tag_pattern = re.compile(r'<(Select|Textarea)\b[^>]*>', re.DOTALL)
+
+for root, _, files in os.walk(directory):
+    for file in files:
+        if file.endswith('.tsx') or file.endswith('.ts'):
+            path = os.path.join(root, file)
+            with open(path, 'r', encoding='utf-8') as f:
+                content = f.read()
+            
+            new_content = content
+            
+            # Replace raw tags with component tags
+            new_content = re.sub(r'<select\b', '<Select', new_content)
+            new_content = new_content.replace('</select>', '</Select>')
+            
+            new_content = re.sub(r'<textarea\b', '<Textarea', new_content)
+            new_content = new_content.replace('</textarea>', '</Textarea>')
+            
+            # Add imports if needed
+            if '<Select' in new_content and 'ui/select' not in new_content:
+                if 'import ' in new_content:
+                    last_import = [m for m in re.finditer(r'^import .*$', new_content, re.MULTILINE)][-1]
+                    new_content = new_content[:last_import.end()] + '\nimport { Select } from "@/components/ui/select";' + new_content[last_import.end():]
+                else:
+                    new_content = 'import { Select } from "@/components/ui/select";\n' + new_content
+                    
+            if '<Textarea' in new_content and 'ui/textarea' not in new_content:
+                if 'import ' in new_content:
+                    last_import = [m for m in re.finditer(r'^import .*$', new_content, re.MULTILINE)][-1]
+                    new_content = new_content[:last_import.end()] + '\nimport { Textarea } from "@/components/ui/textarea";' + new_content[last_import.end():]
+                else:
+                    new_content = 'import { Textarea } from "@/components/ui/textarea";\n' + new_content
+
+            # Replace rounded-xl with rounded in these components
+            new_content = tag_pattern.sub(repl_inner, new_content)
+            
+            if new_content != content:
+                with open(path, 'w', encoding='utf-8') as f:
+                    f.write(new_content)
+                count += 1
+                print('Updated ' + file)
+
+print('Total files updated: ' + str(count))
